"{% endif %}\n\n"
"&lt;h4&gt;Details&lt;/h4&gt;\n\n"
"&lt;ul&gt;\n"
"&lt;li&gt;Customer: {{ doc.customer }}\n"
"&lt;li&gt;Amount: {{ doc.grand_total }}\n"
"&lt;/ul&gt;\n"
"</pre>"
msgstr "<h5>Contoh Pesan</h5>\n\n"
"<pre>&lt;h3&gt;Pesanan Terlambat&lt;/h3&gt;\n\n"
"&lt;p&gt;Transaksi {{ doc.name }} telah melewati Tanggal Jatuh Tempo. Harap ambil tindakan yang diperlukan.&lt;/p&gt;\n\n"
"&lt;!-- show last comment --&gt;\n"
"{% if comments %}\n"
"Komentar terakhir: {{ comments[-1].comment }} oleh {{ comments[-1].by }}\n"
"{% endif %}\n\n"
"&lt;h4&gt;Detail&lt;/h4&gt;\n\n"
"&lt;ul&gt;\n"
"&lt;li&gt;Pelanggan: {{ doc.customer }}\n"
"&lt;li&gt;Jumlah: {{ doc.grand_total }}\n"
"&lt;/ul&gt;\n"
"</pre>"

