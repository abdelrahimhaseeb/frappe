msgid "<pre>*  *  *  *  *\n"
"┬  ┬  ┬  ┬  ┬\n"
"│  │  │  │  │\n"
"│  │  │  │  └ day of week (0 - 6) (0 is Sunday)\n"
"│  │  │  └───── month (1 - 12)\n"
"│  │  └────────── day of month (1 - 31)\n"
"│  └─────────────── hour (0 - 23)\n"
"└──────────────────── minute (0 - 59)\n\n"
"---\n\n"
"* - Any value\n"
